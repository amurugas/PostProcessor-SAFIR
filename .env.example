# PostProcessor-SAFIR – Environment Configuration Template
#
# Copy this file to .env and fill in your local values.
# The .env file is NOT committed to version control.
#
# These variables are read by shared/utils/config.py.

# ─── Logging ─────────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Optional custom log format (Python logging format string)
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ─── Paths ────────────────────────────────────────────────────────────────────
# Directory where SQLite database files are stored
# DB_DIR=.

# Directory where raw SAFIR input/output files are kept
# DATA_DIR=data

# Directory where post-processed exports (CSV, xlsx) are written
# OUTPUT_DIR=output

# ─── Analysis ─────────────────────────────────────────────────────────────────
# Default analysis type used when no explicit type is provided
# Options: thermal | structural
# DEFAULT_ANALYSIS_TYPE=structural
